# TMDb API credentials — get one at https://www.themoviedb.org/settings/api
#
# You can use EITHER a v3 API key (a 32-char hex string) OR a v4 access token
# (a long JWT-style string with dots). Set whichever you have.

# v3 API key (recommended, simplest):
TMDB_API_KEY=

# v4 Read Access Token (optional alternative; used as a Bearer token if set):
# TMDB_ACCESS_TOKEN=

# Port the server listens on (optional, defaults to 3000)
PORT=3000
